      </column>
      <column caption='Sales Per Customers' datatype='real' name='[Calculation_1917060846137349]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/[Calculation_1917060845846532]' />
      </column>
      <column caption='Top N Customers Label' datatype='string' name='[Calculation_2019317383462913]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Top N Customer By Sales]&#13;&#10;THEN &quot;Top &quot; +STR([Parameters].[Parameter 1])+ &quot; Customers&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
